# Clasp Environment Configuration
# Copy to .env and fill in your values.
# This file is safe to commit — .env is gitignored.

# ---------------------------------------------------------------------------
# LLM Provider (used by Root Cause Agent for narration)
# Options: gemini | openai | lmstudio | ollama
# ---------------------------------------------------------------------------
CLASP_LLM_PROVIDER=gemini
CLASP_LLM_MODEL=gemini-2.0-flash

# API Keys
CLASP_GEMINI_API_KEY=your_gemini_api_key_here
CLASP_OPENAI_API_KEY=your_openai_api_key_here

# LM Studio (local, no key needed)
# CLASP_LM_STUDIO_BASE_URL=http://localhost:1234/v1

# ---------------------------------------------------------------------------
# Security (IMPORTANT for production deployments)
# ---------------------------------------------------------------------------

# Pre-shared API key for Bearer token authentication.
# ALL API endpoints require: Authorization: Bearer <CLASP_API_KEY>
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: If unset, all endpoints are publicly accessible (dev only).
CLASP_API_KEY=

# CORS allowed origins (comma-separated, no wildcards in production).
# Set to the URL of your dashboard deployment.
# Example: CLASP_CORS_ORIGINS=http://dashboard.plant.local,https://clasp.mycompany.com
CLASP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------

# Set to true to start the TEP background demo on server boot.
# NEVER set to true on a real plant deployment.
CLASP_DEMO_MODE=false

# Max /api/investigate calls per IP per minute (protects LLM quota)
CLASP_INVESTIGATE_RATE_LIMIT=10

# ---------------------------------------------------------------------------
# Causal Engine Tuning (optional — these are the defaults)
# ---------------------------------------------------------------------------
CLASP_TIME_WINDOW=3600        # seconds to scan forward for causal effects
CLASP_MIN_OCCURRENCES=5       # minimum observations to assert a causal edge
CLASP_MIN_CONFIDENCE=0.7      # confidence threshold for edge creation
CLASP_SIGNIFICANCE_ZSCORE=2.0 # Z-score threshold for "significant change"

# ---------------------------------------------------------------------------
# TEP Simulator (only relevant when CLASP_DEMO_MODE=true)
# ---------------------------------------------------------------------------
CLASP_TEP_DATA_DIR=data/tep
CLASP_TEP_DEFAULT_SPEED=500   # playback speed multiplier for normal data

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
CLASP_API_HOST=0.0.0.0
CLASP_API_PORT=8000
