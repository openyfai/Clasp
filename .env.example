# Clasp Environment Configuration
# Copy to .env and fill in your values.
# This file is safe to commit — .env is gitignored.

# ---------------------------------------------------------------------------
# LLM Provider (used by Root Cause Agent for narration)
# Options: gemini | openai | lmstudio | ollama
# ---------------------------------------------------------------------------
CLASP_LLM_PROVIDER=gemini
CLASP_LLM_MODEL=gemini-2.0-flash

# API Keys
CLASP_GEMINI_API_KEY=your_gemini_api_key_here
CLASP_OPENAI_API_KEY=your_openai_api_key_here

# LM Studio (local, no key needed)
# CLASP_LM_STUDIO_BASE_URL=http://localhost:1234/v1

# ---------------------------------------------------------------------------
# Causal Engine Tuning (optional — these are the defaults)
# ---------------------------------------------------------------------------
CLASP_TIME_WINDOW=3600        # seconds to scan forward for causal effects
CLASP_MIN_OCCURRENCES=5       # minimum observations to assert a causal edge
CLASP_MIN_CONFIDENCE=0.7      # confidence threshold for edge creation
CLASP_SIGNIFICANCE_ZSCORE=2.0 # Z-score threshold for "significant change"

# ---------------------------------------------------------------------------
# TEP Simulator (Phase 2)
# ---------------------------------------------------------------------------
CLASP_TEP_DATA_DIR=data/tep
CLASP_TEP_DEFAULT_SPEED=500   # playback speed multiplier for normal data

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
CLASP_API_HOST=0.0.0.0
CLASP_API_PORT=8000
